<div class="demo-content">
  <h1>ActiveAdmin Dropdown Accessibility Test</h1>
  
  <p>This page simulates ActiveAdmin's dropdown structure to test the accessibility patch. The dropdowns below should be fully keyboard accessible.</p>
  
  <h2>Test Dropdowns</h2>
  
  <!-- Standard ActiveAdmin dropdown -->
  <div class="dropdown">
    <button class="dropdown_button">
      Actions
      <span class="dropdown_arrow"></span>
    </button>
    <ul class="dropdown_menu">
      <li><a href="#">Edit</a></li>
      <li><a href="#">Delete</a></li>
      <li><a href="#">Duplicate</a></li>
    </ul>
  </div>
  
  <!-- Another dropdown with different structure -->
  <div class="dropdown">
    <a href="#" class="dropdown_button">
      More Options
      <span class="dropdown_arrow"></span>
    </a>
    <div class="dropdown_menu">
      <a href="#">Export</a>
      <a href="#">Import</a>
      <a href="#">Archive</a>
    </div>
  </div>
  
  <h2>Testing Instructions</h2>
  
  <ol>
    <li><strong>Tab Navigation:</strong> Use Tab to navigate to dropdown triggers</li>
    <li><strong>Open Dropdown:</strong> Press Enter or Space on a trigger</li>
    <li><strong>Navigate Menu:</strong> Use Arrow Up/Down to move through items</li>
    <li><strong>Quick Navigation:</strong> Use Home/End to jump to first/last item</li>
    <li><strong>Close Dropdown:</strong> Press Escape or Tab</li>
  </ol>
  
  <h2>Expected Behavior</h2>
  
  <ul>
    <li>Dropdown triggers should be focusable with Tab</li>
    <li>Menu items should be focusable when dropdown is open</li>
    <li>Arrow keys should navigate through menu items</li>
    <li>Focus should return to trigger when closing dropdown</li>
    <li>Screen readers should announce menu state and items</li>
  </ul>
  
  <div style="margin-top: 2rem; padding: 1rem; background: #f8f9fa; border-radius: 4px;">
    <h3>Additional Test Elements</h3>
    <p>These elements are here to test tab navigation flow:</p>
    <button>Test Button 1</button>
    <button>Test Button 2</button>
    <a href="#">Test Link</a>
  </div>
</div>

